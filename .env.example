# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — it stays local.

# --- Regions ------------------------------------------------------------------
# Comma-separated list of region names. The report spans every listed region
# by default; the CLI (--region) and the web UI (Regions checkboxes) let you
# scope to a subset.
OS_DB_REGIONS=dfw1,ord1

# Which region's DB connection reaches the shared `keystone` schema.
# Optional; defaults to the first region in OS_DB_REGIONS.
KEYSTONE_REGION=dfw1

# --- Per-region MariaDB replicas ---------------------------------------------
# Suffix form: <REGION_NAME> uppercased, with non-alphanumerics as underscores.
# So `dfw1` → DFW1, `us-east-2` → US_EAST_2.
#
# Any per-region value can fall back to the plain OS_DB_<BASE> form below
# (OS_DB_PORT, OS_DB_USER, ...).

OS_DB_HOST__DFW1=replica-dfw1.internal
OS_DB_PORT__DFW1=3306
OS_DB_USER__DFW1=reporting
OS_DB_PASSWORD__DFW1=

OS_DB_HOST__ORD1=replica-ord1.internal
OS_DB_PORT__ORD1=3306
OS_DB_USER__ORD1=reporting
OS_DB_PASSWORD__ORD1=

# --- Defaults applied when a per-region value is missing ---------------------
# (Also used for legacy single-region deployments: if OS_DB_REGIONS is unset
# but OS_DB_HOST is set, a single region named `default` is synthesized from
# these bare OS_DB_* vars.)
# OS_DB_HOST=127.0.0.1
OS_DB_PORT=3306
OS_DB_USER=reporting

# --- Schema names (rarely changed) -------------------------------------------
KEYSTONE_DB=keystone
NOVA_API_DB=nova_api
CINDER_DB=cinder
GLANCE_DB=glance
NEUTRON_DB=neutron

# --- Web server bind (web.py only) -------------------------------------------
QLR_HOST=127.0.0.1
QLR_PORT=8000

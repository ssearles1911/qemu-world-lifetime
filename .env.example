# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — it stays local.

# --- MariaDB replica (all OpenStack DBs co-located) ---------------------------
OS_DB_HOST=127.0.0.1
OS_DB_PORT=3306
OS_DB_USER=nova
OS_DB_PASSWORD=
KEYSTONE_DB=keystone
NOVA_API_DB=nova_api

# --- Web server bind (web.py only) -------------------------------------------
QLR_HOST=127.0.0.1
QLR_PORT=8000
